{
  "name": "0xsignal-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @0xsignal/api dev",
    "dev:app": "bun run --filter @0xsignal/app dev",
    "build": "bun run --filter '*' build",
    "build:api": "bun run --filter @0xsignal/api build",
    "build:app": "bun run --filter @0xsignal/app build",
    "start": "bun run --filter '*' start",
    "start:api": "bun run --filter @0xsignal/api start",
    "start:app": "bun run --filter @0xsignal/app start",
    "lint": "bun run --filter '*' lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:logs": "docker compose -f docker-compose.db.yml logs -f postgres questdb",
    "db:ps": "docker compose -f docker-compose.db.yml ps",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist",
    "prepare": "husky"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-compiler": "^19.0.0-beta-af1b7da-20250417",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
