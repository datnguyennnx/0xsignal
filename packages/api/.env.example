# API Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=9006
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Database Connections
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_DB=0xsignal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:54322/0xsignal

# ─── Auth Configuration ──────────────────────────────────────────
# JWT & Encryption (MUST change in production)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-256-bit-key-min-32-chars
ENCRYPTION_SECRET=change-me-to-another-random-key-min-32-chars

# Frontend URL (controls CORS)
# Local dev: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# OAuth Provider Configuration
# For production, use your actual OAuth credentials from:
# Google: https://console.cloud.google.com/apis/credentials
# GitHub: https://github.com/settings/developers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:9006/api/auth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:9006/api/auth/github/callback
