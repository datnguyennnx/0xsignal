{
  "name": "@0xsignal/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "dev": "bun --watch presentation/http/server.ts",
    "start": "bun ./dist/server.js",
    "build": "bun run clean && tsc -b tsconfig.json && bun build ./presentation/http/server.ts --target=bun --minify --outdir=./dist",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@0xsignal/auth": "workspace:*",
    "@0xsignal/shared": "workspace:*",
    "@effect/platform-bun": "4.0.0-beta.74",
    "@nktkas/hyperliquid": "^0.32.1",
    "effect": "4.0.0-beta.74",
    "pg": "^8.11.3",
    "viem": "^2.47.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.74",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.0",
    "bun-types": "^1.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.0.14"
  }
}
