{
  "name": "@0xsignal/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "dev": "bun --watch presentation/http/server.ts",
    "dev:mcp": "bun run presentation/mcp/index.ts",
    "start": "bun ./dist/server.js",
    "build": "bun run clean && tsc -b tsconfig.json && bun build ./presentation/http/server.ts --target=bun --minify --outdir=./dist",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "db:up": "docker compose -f docker-compose.yml up -d",
    "db:down": "docker compose -f docker-compose.yml down",
    "db:reset": "docker compose -f docker-compose.yml down -v"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.1",
    "@0xsignal/shared": "workspace:*",
    "@effect/platform": "^0.93.5",
    "@effect/platform-bun": "^0.85.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "effect": "^3.19.5",
    "pg": "^8.11.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@effect/language-service": "^0.56.0",
    "@effect/vitest": "^0.27.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.0",
    "bun-types": "^1.3.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.14"
  }
}
