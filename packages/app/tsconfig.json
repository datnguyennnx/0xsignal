{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "plugins": []
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/**/*.test.tsx", "src/test"]
}
